# Copy to .env and edit for your Home Assistant install.
APP_PORT=8080
APP_BASE_URL=http://localhost:8080
CONFIG_PATH=/data/config.yaml

# Home Assistant long-lived access token settings can live in config.yaml or here.
# HA_URL=http://homeassistant.local:8123
# HA_TOKEN=replace-with-long-lived-token

# Generate with: openssl rand -base64 32
ACTION_TOKEN=replace-with-dashboard-operator-token
ACTION_SIGNING_SECRET=replace-with-long-random-signing-secret

# Enable when HA Print Monitor is behind Caddy, Nginx, Traefik, or HA ingress.
FORWARDED_HEADERS=false

LOG_LEVEL=INFO
JSON_LOGS=false
