"""Sample configuration file for HA Print Monitor."""

app_base_url: "http://localhost:8080"
timezone: "America/Chicago"

home_assistant:
  url: "http://homeassistant.local:8123"
  token: "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."  # Your long-lived token
  camera_entity: "camera.prusa_camera"
  printer_state_entity: "sensor.prusa_print_status"
  printing_states:
    - "printing"
    - "paused"
  pause_service:
    domain: "button"
    service: "press"
    target: "button.prusa_pause_print"
    data: {}
  notify_services:
    - "notify.mobile_app_alex_phone"
    - "notify.mobile_app_family_phone"

# Optional: define multiple printers. If omitted, the app uses the legacy
# home_assistant camera/printer/pause settings above as one default printer.
# printers:
#   - id: "prusa"
#     name: "Prusa"
#     camera_entity: "camera.prusa_camera"
#     printer_state_entity: "sensor.prusa_print_status"
#     printing_states: ["printing", "paused"]
#     pause_service:
#       domain: "button"
#       service: "press"
#       target: "button.prusa_pause_print"
#       data: {}
#     notify_services:
#       - "notify.mobile_app_alex_phone"
#   - id: "voron"
#     name: "Voron"
#     camera_entity: "camera.voron_camera"
#     printer_state_entity: "sensor.voron_print_status"
#     printing_states: ["printing", "paused"]
#     pause_service:
#       domain: "button"
#       service: "press"
#       target: "button.voron_pause_print"
#       data: {}

monitoring:
  # Master switch for all monitoring cycles. Set false to keep the web UI up
  # while stopping camera captures and model analysis.
  enabled: true

  # Seconds between monitoring cycles for each configured printer.
  # Lower values react faster but use more Home Assistant, CPU, and disk I/O.
  frame_interval_seconds: 30

  # Consecutive matching issue frames required before creating/updating an event,
  # sending notifications, or scheduling auto-pause. A clean frame resets the
  # counter. Set to 1 to act on every model detection immediately.
  confirmation_frames: 2

  # Minimum model certainty required before sending a Home Assistant notification.
  # Detections below this value may still be recorded as events.
  certainty_threshold_notify: 0.70

  # Minimum certainty required before scheduling auto-pause. Auto-pause also
  # requires the analyzer result severity to be high or critical.
  certainty_threshold_auto_pause: 0.85

  # Minutes to wait after a qualifying high/critical detection before the app
  # calls the configured pause service automatically.
  auto_pause_delay_minutes: 15

  # Minutes used by dashboard/mobile notification snooze actions.
  snooze_minutes: 15

model:
  provider: "baseline"  # baseline, onnx
  model_path: null  # optional; onnx auto-downloads PrintGuard model.onnx if null
  options_path: null
  prototypes_path: null
  auto_download: true
  models_dir: "/data/models/printguard"
  device: "cpu"

security:
  action_token: "change-me-in-production-to-a-long-random-string"

retention:
  keep_images_days: 7
  keep_events_days: 30
