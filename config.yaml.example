"""Sample configuration file for HA Print Monitor."""

app_base_url: "http://localhost:8080"
timezone: "America/Chicago"

home_assistant:
  url: "http://homeassistant.local:8123"
  token: "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."  # Your long-lived token
  camera_entity: "camera.prusa_camera"
  printer_state_entity: "sensor.prusa_print_status"
  printing_states:
    - "printing"
    # Only states that mean the printer is actively extruding/printing should
    # be listed here. Idle, ready, paused, finished, error, and standby states
    # are intentionally excluded so the app does not take snapshots or run
    # detection when no print is active.
  pause_service:
    domain: "button"
    service: "press"
    target: "button.prusa_pause_print"
    data: {}
  notify_services:
    - "notify.mobile_app_mobile_phone"
    - "notify.mobile_app_family_phone"

# Optional: define multiple printers. If omitted, the app uses the legacy
# home_assistant camera/printer/pause settings above as one default printer.
# printers:
#   - id: "prusa"
#     name: "Prusa"
#     enabled: true
#     camera_entity: "camera.prusa_camera"
#     printer_state_entity: "sensor.prusa_print_status"
#     printing_states: ["printing"]
#     pause_service:
#       domain: "button"
#       service: "press"
#       target: "button.prusa_pause_print"
#       data: {}
#     notify_services:
#       - "notify.mobile_app_mobile_phone"
#   - id: "voron"
#     name: "Voron"
#     enabled: true
#     camera_entity: "camera.voron_camera"
#     printer_state_entity: "sensor.voron_print_status"
#     printing_states: ["printing"]
#     pause_service:
#       domain: "button"
#       service: "press"
#       target: "button.voron_pause_print"
#       data: {}

monitoring:
  # Master switch for all monitoring cycles. Set false to keep the web UI up
  # while stopping camera captures and model analysis.
  enabled: true

  # Seconds between monitoring cycles for each configured printer.
  # Lower values react faster but use more Home Assistant, CPU, and disk I/O.
  frame_interval_seconds: 30

  # Consecutive matching issue frames required before creating/updating an event,
  # sending notifications, or scheduling auto-pause. A clean frame resets the
  # counter. Set to 1 to act on every model detection immediately.
  confirmation_frames: 2

  # Minimum model certainty required before sending a Home Assistant notification.
  # Detections below this value may still be recorded as events.
  certainty_threshold_notify: 0.70

  # Enable automatic pause scheduling for high/critical detections that meet
  # certainty_threshold_auto_pause. Notifications still work when this is false.
  auto_pause_enabled: true

  # Minimum certainty required before scheduling auto-pause. Auto-pause also
  # requires the analyzer result severity to be high or critical.
  certainty_threshold_auto_pause: 0.85

  # Minutes to wait after a qualifying high/critical detection before the app
  # calls the configured pause service automatically.
  auto_pause_delay_minutes: 15

  # Cooldown window shown in the dashboard for operator awareness. This is kept
  # as a protection setting for workflows that suppress repeated action prompts.
  cooldown_minutes: 10

  # Minutes used by dashboard/mobile notification snooze actions.
  snooze_minutes: 15
  min_analysis_interval_seconds: 0
  confirmation_window_minutes: 5
  required_issue_consistency: true

safety:
  require_recent_frame_seconds: 120
  require_printer_still_printing: true
  require_issue_reconfirmation_before_pause: true
  prevent_duplicate_pause: true

camera:
  stale_after_seconds: 120
  capture_timeout_seconds: 15
  retry_count: 2
  retry_backoff_seconds: 3
  fallback_snapshot_url: null

notifications:
  enabled: true
  quiet_hours_enabled: false
  quiet_hours_start: "22:00"
  quiet_hours_end: "07:00"
  notify_on_low: false
  notify_on_medium: true
  notify_on_high: true
  notify_on_critical: true

model:
  provider: "baseline"  # baseline, onnx
  model_path: null  # optional; onnx auto-downloads PrintGuard model.onnx if null
  options_path: null
  prototypes_path: null
  auto_download: true
  models_dir: "/data/models/printguard"
  device: "cpu"
  max_inference_timeout_seconds: 30

security:
  action_token: "change-me-in-production-to-a-long-random-string"
  action_signing_secret: "change-me-to-a-second-long-random-string"
  action_token_ttl_hours: 24

retention:
  keep_images_days: 7
  keep_clear_captures_hours: 24
  keep_event_captures_days: 30
  keep_events_days: 90
  max_capture_storage_mb: 2048

logging:
  json_logs: false
  log_level: "INFO"

proxy:
  forwarded_headers: false
  trusted_hosts: []
